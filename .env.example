BJFUOJ_BASE_URL=https://www.bjfuacm.com
USER_DATA_DIR=.playwright-profile
HEADLESS=false

# LLM is disabled by default. Enable only for local explanation/helper tasks.
ENABLE_LLM=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen2.5-72B-Instruct

# Fill code and click Submit by default. Set false to generate files only.
ENABLE_REMOTE_SUBMIT_ASSIST=true
